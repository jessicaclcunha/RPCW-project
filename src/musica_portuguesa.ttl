@prefix : <http://rpcw.di.uminho.pt/2026/music-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://rpcw.di.uminho.pt/2026/music-ontology/> .

<http://rpcw.di.uminho.pt/2026/music-ontology> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/music-ontology/compostaPor
:compostaPor rdf:type owl:ObjectProperty ;
             rdfs:domain :Musica ;
             rdfs:range :Artista .


###  http://rpcw.di.uminho.pt/2026/music-ontology/contemMusica
:contemMusica rdf:type owl:ObjectProperty ;
              owl:inverseOf :pertenceAoAlbum .


###  http://rpcw.di.uminho.pt/2026/music-ontology/escritaPor
:escritaPor rdf:type owl:ObjectProperty ;
            rdfs:domain :Musica ;
            rdfs:range :Artista .


###  http://rpcw.di.uminho.pt/2026/music-ontology/interpretadaPor
:interpretadaPor rdf:type owl:ObjectProperty ;
                 owl:inverseOf :interpretou ;
                 rdfs:domain :Musica ;
                 rdfs:range :Artista .


###  http://rpcw.di.uminho.pt/2026/music-ontology/interpretou
:interpretou rdf:type owl:ObjectProperty .


###  http://rpcw.di.uminho.pt/2026/music-ontology/lancouAlbum
:lancouAlbum rdf:type owl:ObjectProperty ;
             rdfs:domain :Artista ;
             rdfs:range :Album .


###  http://rpcw.di.uminho.pt/2026/music-ontology/membroDe
:membroDe rdf:type owl:ObjectProperty ;
          owl:inverseOf :temMembro .


###  http://rpcw.di.uminho.pt/2026/music-ontology/pertenceAEditora
:pertenceAEditora rdf:type owl:ObjectProperty ;
                  rdfs:domain :Artista ;
                  rdfs:range :Editora .


###  http://rpcw.di.uminho.pt/2026/music-ontology/pertenceAoAlbum
:pertenceAoAlbum rdf:type owl:ObjectProperty ;
                 rdfs:domain :Musica ;
                 rdfs:range :Album .


###  http://rpcw.di.uminho.pt/2026/music-ontology/pertenceAoGenero
:pertenceAoGenero rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :Album
                                              :Artista
                                              :Musica
                                            )
                              ] ;
                  rdfs:range :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/temMembro
:temMembro rdf:type owl:ObjectProperty ;
           rdfs:domain :Banda ;
           rdfs:range :ArtistaSolo .


#################################################################
#    Data properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/music-ontology/anoFormacao
:anoFormacao rdf:type owl:DatatypeProperty ;
             rdfs:domain :Banda ;
             rdfs:range xsd:integer .


###  http://rpcw.di.uminho.pt/2026/music-ontology/anoLancamento
:anoLancamento rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer .


###  http://rpcw.di.uminho.pt/2026/music-ontology/anoNascimento
:anoNascimento rdf:type owl:DatatypeProperty ;
               rdfs:domain :ArtistaSolo ;
               rdfs:range xsd:integer .


###  http://rpcw.di.uminho.pt/2026/music-ontology/nome
:nome rdf:type owl:DatatypeProperty ;
      rdfs:domain owl:Thing ;
      rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://rpcw.di.uminho.pt/2026/music-ontology/Album
:Album rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Artista
:Artista rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/music-ontology/ArtistaSolo
:ArtistaSolo rdf:type owl:Class ;
             rdfs:subClassOf :Artista ;
             owl:disjointWith :Banda .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Banda
:Banda rdf:type owl:Class ;
       rdfs:subClassOf :Artista .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Editora
:Editora rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Fado
:Fado rdf:type owl:Class ;
      rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Genero
:Genero rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/music-ontology/HipHop
:HipHop rdf:type owl:Class ;
        rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Intervencao
:Intervencao rdf:type owl:Class ;
             rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Kizomba
:Kizomba rdf:type owl:Class ;
         rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Musica
:Musica rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Pimba
:Pimba rdf:type owl:Class ;
       rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Pop
:Pop rdf:type owl:Class ;
     rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/RB
:RB rdf:type owl:Class ;
    rdfs:subClassOf :Genero .


###  http://rpcw.di.uminho.pt/2026/music-ontology/Rock
:Rock rdf:type owl:Class ;
      rdfs:subClassOf :Genero .

